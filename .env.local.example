# ── Sanity CMS ─────────────────────────────────────────────────────────────
# Create a project at https://sanity.io — copy these from the project settings
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_read_token         # Needs "Viewer" role minimum

# ── Resend (contact form email) ─────────────────────────────────────────────
# Create an account at https://resend.com — add and verify your sending domain
RESEND_API_KEY=re_your_api_key
CONTACT_EMAIL_TO=info@cuvon.gr           # Where submitted forms are delivered

# ── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://cuvon.gr    # Used for OG/canonical tags
